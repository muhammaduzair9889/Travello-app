-      url.includes('hotjar') ||
-      url.includes('criteo') ||
-      url.includes('doubleclick') ||
-      url.includes('adservice') ||
-      url.includes('tiqcdn') ||
-      url.includes('sentry')
-    )) {
-      return req.abort();
